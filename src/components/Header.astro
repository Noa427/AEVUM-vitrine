---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/features', label: 'Fonctionnalités' },
  { href: '/pricing', label: 'Tarifs' },
  { href: '/comment-ca-marche', label: 'Comment ça marche' },
];
---

<header role="banner" style="position:relative;z-index:50">
  <nav class="nav" aria-label="Navigation principale">
    <div class="nav__inner">

      <a href="/" class="brand" aria-label="AEVUM — Accueil">
        AEVUM<span class="brand__dot"></span>
      </a>

      <div class="nav__links" id="nav-menu" role="menubar">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            role="menuitem"
            class:list={['nav__link', { 'nav__link--active': currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        ))}
      </div>

      <a href="/contact" class="btn btn--primary nav__cta" role="menuitem">
        Prendre contact
      </a>

      <button class="nav__toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav-menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    {navLinks.map(({ href, label }) => (
      <a href={href} class:list={['nav__mobile-link', { 'is-active': currentPath.startsWith(href) }]}>
        {label}
      </a>
    ))}
    <a href="/contact" class="btn btn--primary" style="margin-top:8px">Prendre contact</a>
  </div>
</header>

<script>
  function initMenu() {
    const toggle = document.querySelector('.nav__toggle') as HTMLButtonElement | null;
    const mobile = document.getElementById('nav-mobile');
    if (!toggle || !mobile) return;
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      mobile.classList.toggle('is-open');
      mobile.setAttribute('aria-hidden', String(isOpen));
    });
  }
  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>

<style>
  /* ── Floating pill nav ── */
  .nav {
    position: sticky;
    top: 16px;
    z-index: 50;
    margin: 16px auto 0;
    padding-left: clamp(20px, 4vw, 56px);
    padding-right: clamp(20px, 4vw, 56px);
    max-width: 1280px;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    padding: 0 8px 0 20px;
    gap: 12px;
    background: rgba(15,15,15,0.82);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 999px;
    box-shadow: 0 8px 24px -8px rgba(0,0,0,0.6), 0 1px 0 rgba(255,255,255,0.04) inset;
  }

  /* Brand */
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    font-family: 'Inter', ui-sans-serif, sans-serif;
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #fafafa;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand__dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #ffffff;
    display: inline-block;
    transform: translateY(-1px);
    box-shadow: 0 0 12px rgba(140,170,255,0.7), 0 0 24px rgba(180,140,255,0.4);
  }

  /* Links */
  .nav__links {
    display: none;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  @media (min-width: 860px) { .nav__links { display: inline-flex; } }

  .nav__link {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: rgba(255,255,255,0.55);
    padding: 7px 13px;
    border-radius: 999px;
    transition: color .2s, background .2s;
    text-decoration: none;
  }
  .nav__link:hover { color: #ffffff; background: rgba(255,255,255,0.07); }
  .nav__link--active { color: #ffffff; background: rgba(255,255,255,0.08); }

  /* CTA */
  .nav__cta {
    font-size: 13.5px !important;
    padding: 9px 18px !important;
    border-radius: 999px !important;
    flex-shrink: 0;
  }

  /* Hamburger */
  .nav__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    background: transparent;
    color: rgba(255,255,255,0.6);
    transition: background .2s, color .2s;
    flex-shrink: 0;
  }
  .nav__toggle:hover { background: rgba(255,255,255,0.08); color: #fff; }
  @media (min-width: 860px) { .nav__toggle { display: none; } }

  /* Mobile menu */
  .nav__mobile {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 16px clamp(20px,4vw,56px);
    background: rgba(10,10,10,0.96);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: 8px;
  }
  .nav__mobile.is-open { display: flex; }

  .nav__mobile-link {
    font-size: 15px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    padding: 12px 4px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: color .2s;
  }
  .nav__mobile-link:hover, .nav__mobile-link.is-active { color: #ffffff; }
</style>
