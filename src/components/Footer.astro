---
const year = new Date().getFullYear();
const links = {
  produit: [
    { href: '/features', label: 'Fonctionnalités' },
    { href: '/pricing', label: 'Tarifs' },
    { href: '/comment-ca-marche', label: 'Comment ça marche' },
    { href: '/contact', label: 'Contact' },
  ],
  legal: [
    { href: '/cgu', label: 'CGU' },
    { href: '/confidentialite', label: 'Confidentialité' },
    { href: '/mentions-legales', label: 'Mentions légales' },
  ],
};
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer__top">

      <div class="footer__brand-col">
        <a href="/" class="footer__brand" aria-label="AEVUM">
          AEVUM
        </a>
        <p class="footer__tagline">L'automatisation email pour infopreneurs et coachs francophones.</p>
      </div>

      <div class="footer__col">
        <h4>Produit</h4>
        <ul>
          {links.produit.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4>Légal</h4>
        <ul>
          {links.legal.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contact</h4>
        <ul>
          <li><a href="/contact">Nous contacter</a></li>
        </ul>
      </div>

    </div>

    <div class="footer__bottom">
      <span>&copy; {year} AEVUM. Tous droits réservés.</span>
      <span class="footer__dot"></span>
      <a href="/mentions-legales">Mentions légales</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding-top: 80px;
    padding-bottom: 40px;
    border-top: 1px solid var(--line);
    margin-top: clamp(80px, 9vw, 144px);
    position: relative;
    z-index: 1;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 56px;
  }
  @media (min-width: 720px) {
    .footer__top { grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 32px; }
  }

  /* Brand */
  .footer__brand {
    display: inline-block;
    font-family: 'Inter', ui-sans-serif, sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 600;
    color: var(--fg);
    text-decoration: none;
    margin-bottom: 16px;
    transition: color .3s;
  }

  .footer__tagline {
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 260px;
    margin: 0;
    transition: color .3s;
  }

  /* Columns */
  .footer__col h4 {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin-bottom: 16px;
    transition: color .3s;
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__col a {
    font-size: 14px;
    color: var(--fg-3);
    transition: color .2s;
    text-decoration: none;
  }
  .footer__col a:hover { color: var(--fg); }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    font-size: 12.5px;
    color: var(--fg-muted);
    transition: color .3s, border-color .3s;
  }
  .footer__bottom a { color: var(--fg-soft); transition: color .2s; }
  .footer__bottom a:hover { color: var(--fg); }

  .footer__dot {
    width: 3px; height: 3px; border-radius: 50%;
    background: var(--line-2);
    display: inline-block;
  }

  @media (max-width: 480px) {
    .footer__top { grid-template-columns: 1fr; }
  }
</style>
