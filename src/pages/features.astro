---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    id: 'crm',
    title: 'CRM & Contacts',
    icon: '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>',
    features: [
      { name: 'Fiches contacts enrichies', desc: 'Centralisez toutes les informations de vos contacts : coordonnées, historique, préférences et interactions.' },
      { name: 'Segmentation intelligente', desc: 'Créez des segments dynamiques basés sur le comportement, le type de bien recherché ou la localisation.' },
      { name: 'Historique des interactions', desc: 'Chaque appel, email et rendez-vous est tracé automatiquement pour un suivi sans faille.' },
      { name: 'Import & export CSV', desc: 'Importez vos contacts existants en un clic et exportez vos données à tout moment.' },
      { name: 'Pipeline personnalisable', desc: 'Adaptez les étapes de votre pipeline de vente à votre processus métier.' },
      { name: 'Tags & filtres avancés', desc: 'Organisez vos contacts avec des tags personnalisés et des filtres multi-critères.' },
    ],
  },
  {
    id: 'ia',
    title: 'Intelligence Artificielle',
    icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
    features: [
      { name: 'Détection de biens', desc: 'L\'IA analyse les signaux faibles pour identifier les propriétaires susceptibles de vendre.' },
      { name: 'Scoring automatique', desc: 'Chaque contact est noté automatiquement selon sa probabilité de conversion.' },
      { name: 'Relances intelligentes', desc: 'L\'IA déclenche les relances au moment optimal pour maximiser les réponses.' },
      { name: 'Suggestions d\'actions', desc: 'Des recommandations personnalisées basées sur l\'analyse de votre portefeuille.' },
      { name: 'Rapprochement acquéreur/bien', desc: 'Match automatique entre les critères de recherche et les biens disponibles.' },
      { name: 'Prédiction de marché', desc: 'Anticipez les tendances de votre secteur grâce à l\'analyse prédictive.' },
    ],
  },
  {
    id: 'gestion',
    title: 'Gestion & Organisation',
    icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
    features: [
      { name: 'Gestion des mandats', desc: 'Suivi complet de chaque mandat : documents, visites, offres et signatures.' },
      { name: 'Agenda partagé', desc: 'Calendrier d\'équipe avec prise de rendez-vous en ligne et rappels automatiques.' },
      { name: 'Gestion documentaire', desc: 'Stockez et partagez tous vos documents : mandats, diagnostics, compromis.' },
      { name: 'Tableau de bord équipe', desc: 'Visualisez les performances de chaque collaborateur en temps réel.' },
      { name: 'Rapports automatiques', desc: 'Rapports de performance générés automatiquement, exportables en PDF.' },
      { name: 'Multi-agences', desc: 'Gérez plusieurs agences depuis un tableau de bord centralisé.' },
    ],
  },
  {
    id: 'detection',
    title: 'Détection & Prospection',
    icon: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
    features: [
      { name: 'Veille marché automatique', desc: 'Surveillance continue des annonces, mutations et mouvements de marché.' },
      { name: 'Alertes en temps réel', desc: 'Notifications instantanées quand une opportunité correspond à vos critères.' },
      { name: 'Zones de prospection', desc: 'Définissez vos secteurs et recevez les alertes géolocalisées.' },
      { name: 'Analyse cadastrale', desc: 'Croisement des données cadastrales pour identifier les propriétaires potentiels.' },
      { name: 'Pige immobilière intégrée', desc: 'Suivi automatique des nouvelles annonces sur les principaux portails.' },
      { name: 'Estimation automatique', desc: 'Estimation de valeur basée sur les comparables et l\'analyse de marché.' },
    ],
  },
];
---

<BaseLayout
  title="Fonctionnalités — AEVUM CRM Immobilier"
  description="Découvrez toutes les fonctionnalités AEVUM : CRM, IA, gestion des mandats, détection de biens et prospection automatisée."
  canonical="/features"
>

<section class="section hero-features" aria-labelledby="features-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="accent-line"></span>
      <h1 id="features-title">Tout ce dont votre agence a besoin</h1>
      <p>4 catégories, 24 fonctionnalités. Un seul outil.</p>
    </div>

    {categories.map((cat) => (
      <div class="feature-category reveal" id={`cat-${cat.id}`}>
        <div class="category-header">
          <div class="icon-box">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={cat.icon} />
          </div>
          <h2>{cat.title}</h2>
        </div>
        <div class="grid-3 feature-grid">
          {cat.features.map((feat) => (
            <div class="card feature-card">
              <h3>{feat.name}</h3>
              <p>{feat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<section class="section cta-section" aria-labelledby="features-cta-title">
  <div class="container" style="text-align:center">
    <div class="reveal" style="display:flex;flex-direction:column;align-items:center">
      <h2 id="features-cta-title">Convaincu ?</h2>
      <p style="margin-top:1rem">Découvrez AEVUM en action avec une démo personnalisée.</p>
      <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;justify-content:center">
        <a href="/demo" class="btn btn-primary" id="features-cta-demo">Demander une démo</a>
        <a href="/pricing" class="btn btn-secondary" id="features-cta-pricing">Voir les tarifs</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .hero-features { padding-top: 8rem; }

  .feature-category {
    margin-bottom: 4rem;
  }

  .feature-category:last-of-type {
    margin-bottom: 0;
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .category-header .icon-box {
    margin-bottom: 0;
  }

  .category-header h2 {
    font-size: 1.5rem;
  }

  .feature-card {
    padding: 1.75rem;
  }

  .feature-card h3 {
    font-size: 1.0625rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9375rem;
  }

  .feature-grid {
    gap: 1.25rem;
  }

  .cta-section {
    background: linear-gradient(135deg, rgba(46, 139, 240, 0.08) 0%, rgba(46, 139, 240, 0.02) 100%);
    border-top: 1px solid rgba(46, 139, 240, 0.15);
  }
</style>
