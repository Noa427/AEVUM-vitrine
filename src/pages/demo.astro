---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Demander une démo — AEVUM CRM Immobilier"
  description="Demandez une démonstration gratuite d'AEVUM. Découvrez comment notre CRM immobilier augmenté par l'IA peut transformer votre agence."
  canonical="/demo"
>

<section class="section hero-demo" aria-labelledby="demo-title">
  <div class="container">
    <div class="demo-grid">
      <div class="demo-info reveal">
        <span class="badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          Gratuit, sans engagement
        </span>
        <h1 id="demo-title">Voyez AEVUM en action</h1>
        <p>Un expert vous présente la plateforme en 30 minutes et répond à toutes vos questions.</p>
        <ul class="demo-benefits">
          <li><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>Démo personnalisée à votre agence</li>
          <li><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>14 jours d'essai gratuit inclus</li>
          <li><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>Aucune carte bancaire requise</li>
          <li><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>Migration assistée offerte</li>
        </ul>
      </div>
      <div class="demo-form-wrapper reveal">
        <form id="demo-form" class="demo-form" novalidate>
          <h2>Réservez votre démo</h2>
          <div class="form-group">
            <label for="demo-prenom" class="form-label">Prénom</label>
            <input type="text" id="demo-prenom" name="prenom" class="form-input" placeholder="Votre prénom" required autocomplete="given-name" />
          </div>
          <div class="form-group">
            <label for="demo-email" class="form-label">Email professionnel</label>
            <input type="email" id="demo-email" name="email" class="form-input" placeholder="vous@agence.fr" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="demo-agence" class="form-label">Nom de l'agence</label>
            <input type="text" id="demo-agence" name="agence" class="form-input" placeholder="Immobilier Dupont" autocomplete="organization" />
          </div>
          <div class="form-group">
            <label for="demo-ville" class="form-label">Ville</label>
            <input type="text" id="demo-ville" name="ville" class="form-input" placeholder="Paris" autocomplete="address-level2" />
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%" id="demo-submit">
            Demander ma démo gratuite
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          <p class="form-legal">En soumettant, vous acceptez notre <a href="/confidentialite">politique de confidentialité</a>.</p>
        </form>
        <div id="demo-success" class="success-msg" style="display:none" role="alert">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          <div><strong>Demande envoyée !</strong><p style="margin-top:0.25rem;font-weight:400;font-size:0.875rem">Un expert AEVUM vous contactera sous 24h.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('demo-form') as HTMLFormElement | null;
  const success = document.getElementById('demo-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    // POST /api/demo-request — Backend à créer plus tard
    console.log('Demo request:', data);
    form.style.display = 'none';
    if (success) success.style.display = 'flex';
  });
</script>

</BaseLayout>

<style>
  .hero-demo { padding-top: 8rem; }
  .demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .demo-info h1 { margin-top: 1.5rem; }
  .demo-info > p { margin-top: 1.5rem; font-size: 1.125rem; }
  .demo-benefits { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .demo-benefits li { display: flex; align-items: center; gap: 0.75rem; font-size: 1rem; color: var(--gray-light); }
  .demo-form-wrapper { background: var(--dark-card); border: 1px solid var(--gray-border); border-radius: var(--radius-lg); padding: 2.5rem; }
  .demo-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .demo-form h2 { font-size: 1.375rem; margin-bottom: 0.5rem; }
  .form-legal { font-size: 0.75rem; color: var(--gray); text-align: center; }
  .form-legal a { color: var(--primary); text-decoration: underline; }
  @media (max-width: 768px) { .demo-grid { grid-template-columns: 1fr; gap: 2.5rem; } }
</style>
