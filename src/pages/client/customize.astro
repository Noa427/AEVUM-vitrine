/* ── Toggle switch actif/inactif pour templates standards ── */
.panel-right-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-shrink: 0;
}
.toggle-switch {
  display: flex;
  align-items: center;
  gap: 0.4375rem;
  cursor: pointer;
  user-select: none;
  flex-shrink: 0;
}
.toggle-input { display: none; }
/* Hide WA/SMS toggle checkboxes (same as .toggle-input) */
.toggle-wa-input,
.toggle-sms-input { display: none; }
.toggle-track {
  position: relative;
  width: 2.25rem;
  height: 1.25rem;
  background: #444;
  border-radius: 0.625rem;
  transition: background 0.2s;
  flex-shrink: 0;
}
.toggle-track::after {
  content: '';
  position: absolute;
  top: 0.125rem;
  left: 0.125rem;
  width: 1rem;
  height: 1rem;
  background: white;
  border-radius: 50%;
  transition: transform 0.2s;
}
.toggle-input:checked + .toggle-track,
.toggle-wa-input:checked + .toggle-track,
.toggle-sms-input:checked + .toggle-track { background: #059669; }
.toggle-input:checked + .toggle-track::after,
.toggle-wa-input:checked + .toggle-track::after,
.toggle-sms-input:checked + .toggle-track::after { transform: translateX(1rem); }
.toggle-label {
  font-size: 0.75rem;
  color: var(--gray-light);
  min-width: 2.5rem;
}
/* Style WA/SMS toggle labels to match existing toggle-label */
.toggle-label-wa,
.toggle-label-sms {
  font-size: 0.75rem;
  color: var(--gray-light);
  min-width: 2.5rem;
  text-align: center;
}
