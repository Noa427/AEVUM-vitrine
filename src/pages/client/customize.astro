    align-items: flex-start;
    gap: 12px;
    background: #1A2035;
    border-left: 3px solid #F59E0B;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 2rem;
  }
  .banner-icon { font-size: 1.25rem; flex-shrink: 0; }
  .default-banner p { margin: 0; font-size: 0.875rem; color: var(--gray-light); flex: 1; }
  .banner-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--gray);
    font-size: 1rem;
    padding: 0;
    flex-shrink: 0;
    line-height: 1;
  }
  .banner-close:hover { color: var(--fg); }

  .customize-section { padding-top: 0; }
  .customize-container { max-width: 700px; }
