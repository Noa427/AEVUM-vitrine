---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

let status: 'idle' | 'sent' | 'error' = 'idle';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const email = (form.get('email') as string ?? '').trim();

    const res = await fetch(`${import.meta.env.AEVUM_URL}/client/forgot-password`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email }),
      signal: AbortSignal.timeout(8000),
    });

    status = res.ok ? 'sent' : 'error';
  } catch {
    status = 'error';
  }
}
---

<BaseLayout
  title="Mot de passe oublié — AEVUM"
  description="Réinitialisez votre mot de passe."
  canonical="/client/forgot-password"
>

<section class="section forgot-section">
  <div class="container">
    <div class="forgot-card card">
      <span class="accent-line" style="margin:0 0 1.5rem"></span>
      <h1 style="font-size:1.5rem;margin-bottom:0.5rem">Mot de passe oublié</h1>

      {status === 'sent' ? (
        <div class="success-msg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p>Si un compte existe avec cet email, vous recevrez un lien de réinitialisation dans quelques minutes.</p>
        </div>
        <a href="/login" class="btn btn-primary" style="width:100%;text-align:center;margin-top:1.5rem">Retour à la connexion</a>
      ) : (
        <>
          <p style="color:var(--gray-light);margin-bottom:2rem">Entrez votre email pour recevoir un lien de réinitialisation.</p>

          {status === 'error' && (
            <div class="form-error" role="alert">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>Une erreur est survenue, réessayez.</span>
            </div>
          )}

          <form method="POST" style="display:flex;flex-direction:column;gap:1.25rem">
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="vous@exemple.fr"
                required
                autocomplete="email"
              />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%">
              Envoyer le lien
            </button>
          </form>
          <div style="text-align:center;margin-top:1.25rem">
            <a href="/login" style="font-size:0.875rem;color:var(--gray-light);text-decoration:none">Retour à la connexion</a>
          </div>
        </>
      )}
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .forgot-section { padding-top: 8rem; }
  .forgot-card {
    max-width: 420px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }
  .success-msg {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid #22C55E;
    border-radius: var(--radius-sm);
    color: #22C55E;
    font-size: 0.9375rem;
  }
  .success-msg svg { flex-shrink: 0; margin-top: 2px; }
  .form-error {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.25rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid #EF4444;
    border-radius: var(--radius-sm);
    color: #EF4444;
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
  }
</style>
